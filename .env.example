# MultiMind AI - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# LLM Providers
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
COHERE_API_KEY=your_cohere_api_key_here

# ============================================
# Search API
# ============================================
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# Cost Optimization
# ============================================
BUDGET_DOLLARS=10.00
SESSION_TIMEOUT_MINUTES=480

# ============================================
# Authentication (Demo)
# ============================================
# In production, use proper secrets management (Azure Key Vault, AWS Secrets Manager)
ADMIN_PASSWORD=admin123
EMPLOYEE_PASSWORD=emp123
CUSTOMER_PASSWORD=cust123
GUEST_PASSWORD=guest123

# ============================================
# Database (for production)
# ============================================
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=multimind
# DB_USER=multimind
# DB_PASSWORD=multimind_password

# ============================================
# Observability
# ============================================
LOG_LEVEL=INFO
ENABLE_TRACING=true
EXPORT_TRACES=false

# ============================================
# AWS Deployment (optional)
# ============================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=multimind-documents
